# Server
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
BASE_URL=http://localhost:8080

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=shortener
DB_PASSWORD=shortener_dev
DB_NAME=url_shortener
DB_SSLMODE=disable

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=change-me-in-production-use-a-strong-random-key
JWT_EXPIRE_HOURS=72

# Rate Limit
RATE_LIMIT_GLOBAL=100
RATE_LIMIT_CREATE=10

# GeoIP (optional, download from MaxMind)
GEOIP_DB_PATH=./data/GeoLite2-City.mmdb
